# GEMINI_API_KEY: Required for Gemini AI API calls.
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# APP_URL: The URL where this app is hosted.
# e.g. https://your-domain.com
APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com

# BUILDER CODE: ERC-8021 attribution suffix for Base onchain analytics.
# Get your code from: https://base.dev → Settings → Builder Codes
NEXT_PUBLIC_BUILDER_CODE=bc_your_builder_code_here

# BASE PAY: Accept USDC payments via Base Pay
# NEXT_PUBLIC_PAYMENT_ADDRESS — the wallet address that receives USDC
# NEXT_PUBLIC_BASEPAY_TESTNET — set "true" to use Base Sepolia (test USDC); omit or "false" for mainnet
NEXT_PUBLIC_PAYMENT_ADDRESS=0xYourPaymentAddressHere
NEXT_PUBLIC_BASEPAY_TESTNET=true

# CDP (Coinbase Developer Platform)
# Get your API key and Paymaster URL from: https://portal.cdp.coinbase.com → API Keys
# Paymaster URL enables gas sponsorship for smart wallet transactions
CDP_CLIENT_API_KEY=your_cdp_client_api_key_here
CDP_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base/your_cdp_client_api_key_here
NEXT_PUBLIC_CDP_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base/your_cdp_client_api_key_here

